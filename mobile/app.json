{
  "expo": {
    "name": "TVK Mylapore",
    "slug": "tvk-mylapore",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#173628"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.tvk.mylapore",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "TVK Mylapore needs your location to attach the spot of your grievance so we can dispatch field teams to the right place.",
        "NSCameraUsageDescription": "TVK Mylapore needs camera access so you can attach photos to your grievance.",
        "NSPhotoLibraryUsageDescription": "TVK Mylapore needs gallery access so you can attach photos to your grievance."
      }
    },
    "android": {
      "package": "in.tvk.mylapore",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {},
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow TVK Mylapore to use your location to tag grievances."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow TVK Mylapore to access your photos so you can attach images to grievances.",
          "cameraPermission": "Allow TVK Mylapore to use your camera to capture grievance photos."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0b3d2e"
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "extraProguardRules": "-keep class com.facebook.hermes.unicode.** { *; }\n-keep class com.facebook.jni.** { *; }"
          }
        }
      ],
      [
        "./plugins/withAbiSplit",
        { "abis": ["arm64-v8a"] }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://tvk-mla-support.onrender.com/api",
      "eas": {
        "projectId": "b1500399-09b1-46bc-bb85-319f3108bb02"
      }
    },
    "owner": "greenlabs8106"
  }
}
